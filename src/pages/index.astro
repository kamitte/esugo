---
import Layout from "../layouts/Layout.astro";

const works = [
  {
    name: "Plantoto",
    meta: "植物管理アプリ — iOS / Android",
    description:
      "お手入れの記録・リマインド、成長記録ができるアプリ。いつしたか忘れがちな植物のお世話を、無理なく続けられます。",
    links: [
      {
        label: "App Store",
        href: "https://apps.apple.com/jp/app/%E8%A6%B3%E8%91%89%E6%A4%8D%E7%89%A9-%E5%AE%B6%E5%BA%AD%E8%8F%9C%E5%9C%92%E3%81%AE%E6%A4%8D%E7%89%A9%E7%AE%A1%E7%90%86-plantoto/id6670186137",
      },
      {
        label: "Google Play",
        href: "https://play.google.com/store/apps/details?id=com.esugo.plantCare&hl=ja",
      },
    ],
  },
  {
    name: "バドデスク",
    meta: "バドミントン大会運営ソフト — Windows / Mac",
    description:
      "組み合わせ作成、結果集計、スコアシート出力、賞状出力までを一気に効率化。大会運営者の煩雑な作業をラクにします。",
    links: [{ label: "詳しく見る", href: "https://badminton-lp.pages.dev/" }],
  },
];

const heroLead =
  "エスゴは、ソフトウェア開発、特にアプリ開発を中心に手がけています。自社サービスの企画・開発・運営から、お客様のプロダクトを支える開発まで、確かな技術と経験でお応えします。";

const services = [
  {
    num: "01",
    title: "アプリ開発",
    body: "Flutter を用いたクロスプラットフォーム開発で、iOS / Android / Windows / Mac の各環境向けにアプリを構築します。",
  },
  {
    num: "02",
    title: "ソフトウェア開発全般",
    body: "Webサイト・バックエンド・業務システムなど、アプリ以外の領域も対応。要件定義から実装まで一貫して開発します。",
  },
  {
    num: "03",
    title: "新規事業の支援",
    body: "0 → 1 の立ち上げ経験をベースに、企画段階からの相談・技術選定・プロトタイピングをサポートします。",
  },
];

const aboutParagraphs = [
  "京都大学卒業後、大手 IT コンサルティング会社にて、ネット証券のシステム開発に従事。その後、AI 系スタートアップにて新規事業の企画から開発・運営までを一気通貫で担当。7 年の会社員経験を経て、エスゴとして独立。",
  "大規模システムの堅牢さと、スタートアップのスピード感、その両方の感覚を持って、事業に役立つソフトウェアを届けたいと考えています。",
];

const contactLead = "ご相談・お見積りなど、お気軽にお問い合わせください。";
---

<Layout>
  <header class="site-header">
    <div class="container header-inner">
      <a href="#top" class="brand">エスゴ</a>
      <nav class="site-nav">
        <a href="#services">事業</a>
        <a href="#works">実績</a>
        <a href="#about">代表</a>
        <a href="#contact">お問い合わせ</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="container hero-inner">
        <p class="eyebrow">SOFTWARE DEVELOPMENT STUDIO</p>
        <h1 class="hero-title">エスゴ</h1>
        <p class="hero-tagline">想像を、少し超えるものを。</p>
        <p class="hero-lead">{heroLead}</p>
      </div>
    </section>

    <section id="services" class="section">
      <div class="container">
        <p class="section-eyebrow">SERVICES</p>
        <h2 class="section-title">事業内容</h2>
        <div class="services-grid">
          {
            services.map((service) => (
              <article class="service-card">
                <span class="service-num">{service.num}</span>
                <h3>{service.title}</h3>
                <p>{service.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="works" class="section section-alt">
      <div class="container">
        <p class="section-eyebrow">WORKS</p>
        <h2 class="section-title">自社サービス</h2>
        <div class="works-grid">
          {
            works.map((work) => (
              <article class="work-card">
                <h3>{work.name}</h3>
                <p class="work-meta">{work.meta}</p>
                <p class="work-body">{work.description}</p>
                <div class="work-links">
                  {work.links.map((link) => (
                    <a class="link-arrow" href={link.href}>
                      {link.label} <span aria-hidden="true">→</span>
                    </a>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="about" class="section">
      <div class="container about-grid">
        <div class="about-meta">
          <p class="section-eyebrow">ABOUT</p>
          <h2 class="section-title">代表</h2>
        </div>
        <div class="about-body">
          <p class="about-name">
            黒木 修弥<span class="about-name-en">Shuya Kuroki</span>
          </p>
          {aboutParagraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <section id="contact" class="section section-dark">
      <div class="container contact-inner">
        <p class="section-eyebrow light">CONTACT</p>
        <h2 class="section-title light">お問い合わせ</h2>
        <p class="contact-lead">{contactLead}</p>
        <a class="contact-mail" href="mailto:kamitte5@gmail.com"
          >kamitte5@gmail.com</a
        >
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <p class="brand-small">エスゴ</p>
        <p class="footer-tagline">Software Development Studio</p>
      </div>
      <dl class="footer-meta">
        <div>
          <dt>代表</dt>
          <dd>黒木 修弥</dd>
        </div>
        <div>
          <dt>設立</dt>
          <dd>2025 年</dd>
        </div>
        <div>
          <dt>所在地</dt>
          <dd>
            〒150-0043<br />
            東京都渋谷区道玄坂1丁目10番8号渋谷道玄坂東急ビル2F−C
          </dd>
        </div>
      </dl>
    </div>
    <div class="container copyright">
      <p>© 2026 Esugo. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 249, 246, 0.85);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .brand {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .brand:hover {
    opacity: 1;
  }

  .site-nav {
    display: flex;
    gap: 32px;
  }

  .site-nav a {
    color: var(--fg-muted);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .site-nav a:hover {
    color: var(--accent);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .site-nav {
      gap: 18px;
    }
    .site-nav a {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .site-nav {
      display: none;
    }
  }

  /* Hero */
  .hero {
    padding: 140px 0 120px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    right: -120px;
    width: 480px;
    height: 480px;
    background: radial-gradient(
      circle at center,
      rgba(20, 32, 45, 0.05),
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
  }

  .eyebrow,
  .section-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    font-weight: 600;
    color: var(--fg-subtle);
    margin: 0 0 24px;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0 0 32px;
    font-size: clamp(3rem, 9vw, 5.75rem);
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .hero-tagline {
    font-size: clamp(1.3rem, 3vw, 1.75rem);
    font-weight: 600;
    margin: 0 0 36px;
    color: var(--fg);
    letter-spacing: 0.03em;
  }

  .hero-lead {
    max-width: 640px;
    font-size: 1rem;
    color: var(--fg-muted);
    line-height: 2;
    margin: 0;
  }

  /* Section */
  .section {
    padding: 110px 0;
    border-bottom: 1px solid var(--border);
  }

  .section-alt {
    background: var(--bg-elevated);
  }

  .section-title {
    margin: 0 0 60px;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  /* Services */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  .service-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 36px 32px;
    position: relative;
  }

  .section-alt .service-card {
    background: var(--bg);
  }

  .service-num {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--fg-subtle);
    margin-bottom: 18px;
  }

  .service-card h3 {
    margin: 0 0 14px;
    font-size: 1.2rem;
    color: var(--accent);
  }

  .service-card p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.95rem;
    line-height: 1.9;
  }

  /* Works */
  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 28px;
  }

  .work-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 44px 36px;
    display: flex;
    flex-direction: column;
  }

  .section-alt .work-card {
    background: var(--bg-elevated);
  }

  .work-card h3 {
    margin: 0 0 8px;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .work-meta {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    letter-spacing: 0.05em;
    margin: 0 0 24px;
    font-weight: 600;
  }

  .work-body {
    margin: 0 0 32px;
    color: var(--fg);
    line-height: 1.95;
    font-size: 0.97rem;
  }

  .work-links {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 12px 28px;
  }

  .link-arrow {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 4px;
    letter-spacing: 0.05em;
  }

  .link-arrow span {
    display: inline-block;
    margin-left: 4px;
    transition: transform 0.2s;
  }

  .link-arrow:hover {
    opacity: 1;
  }

  .link-arrow:hover span {
    transform: translateX(4px);
  }

  /* About */
  .about-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 72px;
    align-items: start;
  }

  @media (max-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .about-meta .section-title {
    margin-bottom: 0;
  }

  .about-name {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0 0 36px;
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .about-name-en {
    display: block;
    font-size: 0.8rem;
    color: var(--fg-subtle);
    letter-spacing: 0.25em;
    font-weight: 500;
    margin-top: 6px;
    text-transform: uppercase;
  }

  .about-body p {
    color: var(--fg-muted);
    line-height: 2.05;
    margin: 0 0 22px;
    font-size: 0.97rem;
  }

  .about-body p:last-child {
    margin-bottom: 0;
  }

  /* Contact */
  .section-dark {
    background: var(--accent);
    color: #f5f3ee;
    border-bottom: none;
    padding: 100px 0;
  }

  .contact-inner {
    text-align: center;
  }

  .section-eyebrow.light {
    color: rgba(255, 255, 255, 0.55);
  }

  .section-title.light {
    color: #fff;
    margin-bottom: 28px;
  }

  .contact-lead {
    margin: 0 0 48px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1rem;
  }

  .contact-mail {
    display: inline-block;
    font-size: clamp(1.25rem, 3.5vw, 1.85rem);
    font-weight: 600;
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    padding-bottom: 8px;
    letter-spacing: 0.03em;
  }

  .contact-mail:hover {
    border-bottom-color: #fff;
    opacity: 1;
  }

  /* Footer */
  .site-footer {
    background: var(--accent-deep);
    color: rgba(255, 255, 255, 0.55);
    padding: 64px 0 32px;
    font-size: 0.875rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .brand-small {
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0 0 8px;
  }

  .footer-tagline {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }

  .footer-meta {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px 32px;
  }

  .footer-meta div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer-meta dt {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .footer-meta dd {
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
  }

  .footer-meta dd a {
    color: inherit;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    padding-bottom: 1px;
  }

  .copyright {
    padding-top: 32px;
  }

  .copyright p {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.05em;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
    .link-arrow span {
      transition: none;
    }
  }
</style>
